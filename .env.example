# =============================================================================
# NammaPark RPi Device Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- MQTT Broker (HiveMQ Cloud) ---
MQTT_BROKER=your_broker.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# --- Device Identity ---
# Unique name for this RPi device (used in heartbeat payloads)
DEVICE_ID=RPi-Plot-1
# The plot ID this device manages (must match backend's plot_id)
PLOT_ID=1

# --- Heartbeat ---
# Interval in seconds between heartbeat messages (minimum 10)
HEARTBEAT_INTERVAL=60

# --- Reconnect ---
RECONNECT_MAX_ATTEMPTS=0       # 0 = unlimited reconnect attempts
RECONNECT_BASE_DELAY=1.0       # Initial reconnect delay (seconds)
RECONNECT_MAX_DELAY=60.0       # Maximum reconnect delay via exponential backoff

# --- Logging ---
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# Hardware / GPIO Configuration (BCM pin numbering)
# =============================================================================
#
# A single servo motor controls the main parking gate barrier.
#
# Wiring (SG90 / MG90S):
#   Servo signal wire → SERVO_PIN (BCM GPIO)
#   Servo VCC         → 5 V rail
#   Servo GND         → Common ground
#
# Duty cycle for standard servos at 50 Hz:
#   2.5% ≈ 0°  (gate closed / barrier down)
#   7.5% ≈ 90° (gate open  / barrier raised)

SERVO_PIN=18
SERVO_PWM_FREQ=50
SERVO_OPEN_DUTY=7.5
SERVO_CLOSE_DUTY=2.5

# Seconds to hold gate open before automatically closing
SERVO_OPEN_DURATION=5

# =============================================================================
# Camera / QR Configuration (Pi Camera Module V2)
# =============================================================================
#
# Uses picamera2 (libcamera stack) to capture frames from the Pi Camera
# Module V2, and OpenCV QRCodeDetector to decode QR codes from those frames.
#
# Pi Camera setup (run on the Pi):
#   sudo raspi-config → Interface Options → Camera → Enable
#   Verify: libcamera-hello   (should show a camera preview)
#
# Install dependencies:
#   sudo apt install -y python3-picamera2        # Pi Camera driver
#   pip install opencv-python-headless           # QR decoding (no GUI)

# Capture resolution (lower = faster scan; 640x480 is a good balance)
CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# Seconds between frame captures (0.5 = ~2 scans/second)
QR_SCAN_INTERVAL=0.5

# Seconds to ignore repeat scans of the same QR (prevents duplicate MQTT events)
QR_COOLDOWN=10

# CAMERA_INDEX is not used with picamera2 (kept for compatibility)
CAMERA_INDEX=0
