# =============================================================================
# NammaPark RPi Device Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- MQTT Broker (HiveMQ Cloud) ---
MQTT_BROKER=d311003abb5f4709bc7f92791eb3f7c7.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# --- Device Identity ---
# Unique name for this RPi device (used in heartbeat payloads)
DEVICE_ID=RPi-Plot-1
# The plot ID this device is assigned to (must match backend's plot_id)
PLOT_ID=1

# --- Heartbeat ---
# How often to send heartbeat to backend (seconds)
HEARTBEAT_INTERVAL=60

# --- Slot Capacity (static, will be replaced by sensor data later) ---
TOTAL_SLOTS_2W=5
TOTAL_SLOTS_4W=3

# --- Logging ---
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
